# ── Google Gemini ─────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here

# ── Tavily (Web Search) ───────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── Gmail SMTP (Email Notifications — zero signup needed) ─────
# Use a Gmail account + App Password (NOT your real Gmail password)
#
# How to get an App Password (takes ~2 minutes):
#   1. Go to → myaccount.google.com/security
#   2. Enable "2-Step Verification" if not already on
#   3. Search "App Passwords" in Google Account settings
#   4. Click "Create app password"
#      App: Mail  |  Device: Other  |  Name: "Chronic Chatbot"
#   5. Google shows a 16-character key like: abcd efgh ijkl mnop
#      Paste it below WITHOUT spaces: abcdefghijklmnop
#
GMAIL_SENDER_EMAIL=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# ── Google Calendar OAuth (Optional) ─────────────────────────
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials/google_calendar_credentials.json
GOOGLE_CALENDAR_TOKEN_PATH=credentials/google_calendar_token.json

# ── Database ──────────────────────────────────────────────────
SQLITE_DB_PATH=data/chronic_chatbot.db

# ── ChromaDB (Vector Store) ───────────────────────────────────
CHROMA_PERSIST_DIR=data/chroma_store

# ── App Settings ─────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
MAX_AGENT_ITERATIONS=10
